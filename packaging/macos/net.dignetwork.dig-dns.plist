<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Label</key>
	<string>net.dignetwork.dig-dns</string>
	<key>ProgramArguments</key>
	<array>
		<string>/usr/local/bin/dig-dns</string>
		<string>serve</string>
	</array>
	<key>RunAtLoad</key>
	<true/>
	<key>KeepAlive</key>
	<true/>
	<key>EnvironmentVariables</key>
	<dict>
		<key>DIG_DNS_STATE_DIR</key>
		<string>/Library/Application Support/DigDns</string>
	</dict>
	<key>StandardOutPath</key>
	<string>/Library/Logs/DigDns/dig-dns.log</string>
	<key>StandardErrorPath</key>
	<string>/Library/Logs/DigDns/dig-dns.log</string>
	<key>ProcessType</key>
	<string>Adaptive</string>
</dict>
</plist>
