#!/bin/sh
# dig-dns macOS .pkg POSTINSTALL (#503).
#
# Create the machine-wide state + log dirs (SPEC §13.5), then (re)bootstrap + enable the
# LaunchDaemon so the service starts now and on every boot (RunAtLoad in the plist).
set -e

PLIST=/Library/LaunchDaemons/net.dignetwork.dig-dns.plist

# Machine-wide, identity-independent state dir (runtime.json) + logs.
mkdir -p "/Library/Application Support/DigDns"
chmod 755 "/Library/Application Support/DigDns"
mkdir -p /Library/Logs/DigDns

# launchd requires the plist be owned root:wheel and not group/world-writable.
chown root:wheel "$PLIST"
chmod 644 "$PLIST"

# Clean-reinstall: bootout any lingering instance (preinstall already tried; harmless if gone),
# then bootstrap the new daemon into the system domain and enable it. bootstrap/enable are
# best-effort (|| true): the plist's RunAtLoad starts the daemon regardless, and a benign
# launchctl return (e.g. a transient domain state) must not fail the whole install.
/bin/launchctl bootout system/net.dignetwork.dig-dns 2>/dev/null || true
/bin/launchctl bootstrap system "$PLIST" || true
/bin/launchctl enable system/net.dignetwork.dig-dns || true

# Wire OS-level *.dig resolution so the package alone makes *.dig resolve system-wide (#530):
# the boot-persistent 127.0.0.5 lo0 alias (a FUNCTIONAL PREREQUISITE — macOS answers only
# 127.0.0.1 on lo0 without it), /etc/resolver/dig, and a DNS-cache flush (SPEC §15). Unconditional
# on macOS (a .pkg has no opt-out prompt), best-effort (|| true) so a resolver hiccup never fails
# the install; reverse it with /usr/local/share/dig-dns/uninstall.sh. It does NOT set a managed
# browser policy (that is the --browser-policy opt-in, which the package never passes).
/usr/local/bin/dig-dns configure-os || true

exit 0
